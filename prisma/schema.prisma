generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["user_service"]
}

model UserRole {
  id          Int     @id
  roleName    String  @unique @map("role_name") @db.VarChar(50)
  description String?
  users       User[]

  @@map("user_roles")
  @@schema("user_service")
}

model UserChannel {
  id          Int     @id
  channelName String  @unique @map("channel_name") @db.VarChar(50)
  description String?
  users       User[]

  @@map("user_channels")
  @@schema("user_service")
}

model User {
  username      String?       @unique @db.VarChar(50)
  email         String        @unique @db.VarChar(100)
  phoneNumber   String?       @unique @map("phone_number") @db.VarChar(20)
  passwordHash  String        @map("password_hash")
  roleId        Int           @map("role_id")
  userChannelId Int           @map("user_channel_id")
  isActive      Boolean?      @default(true) @map("is_active")
  lastLoginAt   DateTime?     @map("last_login_at") @db.Timestamp(6)
  createdAt     DateTime?     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime?     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  id            Int           @id @default(autoincrement())
  addresses     UserAddress[]
  userChannel   UserChannel   @relation(fields: [userChannelId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_channel")
  role          UserRole      @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_role")

  @@map("users")
  @@schema("user_service")
}

model UserAddress {
  id           Int       @id
  addressLine1 String    @map("address_line1") @db.VarChar(255)
  addressLine2 String?   @map("address_line2") @db.VarChar(255)
  city         String?   @db.VarChar(100)
  district     String?   @db.VarChar(100)
  postalCode   String?   @map("postal_code") @db.VarChar(20)
  country      String?   @default("Sri Lanka") @db.VarChar(100)
  isDefault    Boolean?  @default(false) @map("is_default")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  userId       Int       @map("user_id")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")

  @@map("user_addresses")
  @@schema("user_service")
}
