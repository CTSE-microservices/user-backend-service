# Server
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/user_service?schema=user_service"

# JWT
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRES_IN=7d
JWT_EXPIRATION_HOURS=24
JWT_ISSUER=UserService
JWT_AUDIENCE=UserServiceClient

# App
API_PREFIX=/api/v1
