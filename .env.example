# Server
NODE_ENV=development
PORT=4000

# Database (PostgreSQL)
# Do not wrap in "quotes" — Docker --env-file includes them in the value and Prisma fails with P1012.
DATABASE_URL=postgresql://postgres.ipspbpifkbxbuxfqafdj:dh84%40huH%237dn%263hd@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# Messaging / Cache
# LOCAL: use these when RabbitMQ runs on your machine (e.g. docker-compose).
# CLOUD: get a URL from CloudAMQP (or similar) and replace with their connection string (e.g. amqps://user:pass@host/vhost).
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=user.events
RABBITMQ_USER_REGISTERED_QUEUE=user-service.user-registered
RABBITMQ_USER_REGISTERED_ROUTING_KEY=user.registered
ENABLE_USER_REGISTERED_CONSUMER=true

# LOCAL: use this when Redis runs on your machine (e.g. docker-compose).
# CLOUD: get a URL from Redis Cloud, Upstash, etc. and replace (e.g. rediss://default:password@host:port).
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=60

# JWT
JWT_SECRET=9TWpjmw8EvXCXcATUPF4t8efBmX1Dizo13k4HTP5mIG
JWT_EXPIRES_IN=7d
JWT_EXPIRATION_HOURS=24
JWT_ISSUER=UserService
JWT_AUDIENCE=UserServiceClient

# App
API_PREFIX=/api/v1
